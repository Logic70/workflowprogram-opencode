{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "python3*": "allow",
      "python *": "allow",
      "*python.exe*": "allow",
      "*bin/python*": "allow",
      "rg*": "allow",
      "find*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "git status*": "allow",
      "git diff*": "allow"
    }
  },
  "watcher": {
    "ignore": [
      ".workflowprogram/runs/**",
      "__pycache__/**",
      "*.pyc"
    ]
  }
}
